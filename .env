# Discord bot token (gizli)
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Opsiyonel: Tek sunuculuk test sunucusu ID'si (isteğe bağlı)
GUILD_ID=YOUR_GUILD_ID_HERE

# Spotify API (Client ID / Secret) - gizli
SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID_HERE
SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET_HERE

# cookies.txt yolu (YouTube 403 için). göreli ya da mutlak yol yaz.
COOKIES_PATH=./cookies.txt

# Yerel müzik önbelleği dizini
MUSIC_CACHE_PATH=./music_cache

# Önbellek limiti (GB)
CACHE_LIMIT_GB=80

# Bot sahibi kullanıcı ID'si (opsiyonel)
OWNER_ID=YOUR_USER_ID_HERE

# Çalışma modu (development|production)
NODE_ENV=development
